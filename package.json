{
  "name": "tapt-v6",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Tennessee Association of Pupil Transportation Website",
  "scripts": {
    "dev": "vite",
    "build": "npm run clean && vite build",
    "build:strict": "npm run clean && tsc -b && vite build",
    "build:production": "NODE_ENV=production npm run build",
    "build:analyze": "npm run build && npx vite-bundle-analyzer dist/",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "lint:warn": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 50",
    "preview": "vite preview --host 0.0.0.0",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "start": "npm run dev",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:security": "node scripts/test-input-sanitization.js",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:reset": "npx supabase db reset",
    "supabase:gen-types": "npx supabase gen types typescript --local > src/types/database.types.ts",
    "deploy:functions": "npx supabase functions deploy",
    "deploy:secrets": "npx supabase secrets set TURNSTILE_SECRET_KEY=$TURNSTILE_SECRET_KEY",
    "deploy:secrets:example": "npx supabase secrets set TURNSTILE_SECRET_KEY=0x4AAAAAABkM5w2rxee0cGv5Fax08rrZzIo",
    "check:security": "npm audit && npm outdated",
    "update:deps": "npm update",
    "check:all": "npm run type-check && npm run lint && npm run format:check && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.5",
    "date-fns": "^3.6.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.525.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "react-window": "^1.8.11",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^22.16.3",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.0.7",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.15.0",
    "postcss": "^8.5.6",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "rimraf": "^6.0.1",
    "supabase": "^2.30.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "transportation",
    "education",
    "tennessee",
    "react",
    "typescript",
    "vite",
    "supabase",
    "tailwindcss"
  ],
  "author": "Tennessee Association of Pupil Transportation",
  "license": "MIT"
}
